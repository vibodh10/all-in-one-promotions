{% if template.name == 'product' and product %}
  {% assign variant_id = product.selected_or_first_available_variant.id %}

  <div
    id="smart-offer-root-{{ section.id }}"
    class="smart-offer"
    data-variant-id="{{ variant_id }}"
    data-product-gid="gid://shopify/Product/{{ product.id }}"
    data-shop="{{ shop.permanent_domain }}">
    <div class="smart-offer__loading">Loading offer…</div>
  </div>

  <style>
    .smart-offer{border:1px solid rgba(0,0,0,.12);border-radius:14px;padding:18px;margin-top:14px;background:#fff}
    .smart-offer__title{display:flex;align-items:center;gap:10px;font-size:22px;font-weight:700;margin:0 0 8px}
    .smart-offer__desc{margin:0 0 14px;opacity:.8}
    .smart-offer__tiers{display:flex;flex-direction:column;gap:10px;margin:0 0 16px;padding:0;list-style:none}
    .smart-offer__tier{border:1px solid rgba(0,0,0,.12);border-radius:12px;padding:12px 12px}
    .smart-offer__tier label{display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer}
    .smart-offer__left{display:flex;align-items:center;gap:10px}
    .smart-offer__badge{font-weight:700}
    .smart-offer__save{font-weight:800}
    .smart-offer__btn{width:100%;border-radius:12px;padding:14px 16px;font-weight:800;border:0;cursor:pointer}
    .smart-offer__btn[disabled]{opacity:.5;cursor:not-allowed}
    .smart-offer__error{margin-top:10px;color:#b00020;font-size:14px}
  </style>

  <script>
    (function () {
      const root = document.getElementById("smart-offer-root-{{ section.id }}");
      if (!root) return;

      const variantId = root.dataset.variantId;
      const productGid = root.dataset.productGid;
      const shop = root.dataset.shop;

      const qs = (sel) => root.querySelector(sel);

      function fmtSave(offer, tier) {
        const t = (offer.discountType || "").toLowerCase();
        // Support either "percentage" / "percentage_off" etc OR "fixed_amount"
        if (t.includes("percent")) return `Save ${Number(tier.discount)}%`;
        // Fixed amount (you can enhance later with currency)
        return `Save ${Number(tier.discount)}`;
      }

      function render(offer) {
        const tiers = Array.isArray(offer.tiers) ? offer.tiers : [];

        if (!tiers.length) {
          root.innerHTML = `<div class="smart-offer__error">No tiers found for this offer.</div>`;
          return;
        }

        // Build list items (radio)
        const tierLis = tiers.map((t, idx) => {
          const qty = Number(t.quantity);
          const saveText = fmtSave(offer, t);

          return `
            <li class="smart-offer__tier">
              <label>
                <span class="smart-offer__left">
                  <input type="radio" name="smart-tier" value="${qty}" ${idx === 0 ? "checked" : ""} />
                  <span class="smart-offer__badge">Buy ${qty}</span>
                </span>
                <span class="smart-offer__save">${saveText}</span>
              </label>
            </li>
          `;
        }).join("");

        root.innerHTML = `
          <div class="smart-offer__title">
            <span aria-hidden="true">🎁</span>
            <span>${offer.name || "Offer"}</span>
          </div>
          ${offer.description ? `<p class="smart-offer__desc">${offer.description}</p>` : ``}

          <ul class="smart-offer__tiers">
            ${tierLis}
          </ul>

          <button type="button" class="smart-offer__btn" id="smart-offer-add-{{ section.id }}">
            Add bundle to cart
          </button>

          <div class="smart-offer__error" style="display:none"></div>
        `;

        const btn = qs("#smart-offer-add-{{ section.id }}");
        const errBox = qs(".smart-offer__error");

        async function addToCart(quantity) {
          // Add selected quantity of current product variant
          const res = await fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json", "Accept": "application/json" },
            body: JSON.stringify({
              items: [{ id: Number(variantId), quantity: Number(quantity) }]
            })
          });

          if (!res.ok) {
            const txt = await res.text();
            throw new Error(txt || "Failed to add to cart");
          }

          return res.json();
        }

        function getDiscountCodeForQty(qty) {
          // Preferred: per-tier codes (offer.tierCodes = { "2": "CODE2", "3": "CODE3" })
          if (offer.tierCodes && typeof offer.tierCodes === "object") {
            const code = offer.tierCodes[String(qty)];
            if (code) return code;
          }
          // Fallback: single code for offer
          if (offer.shopifyDiscountCode) return offer.shopifyDiscountCode;

          return null;
        }

        btn.addEventListener("click", async () => {
          const selected = root.querySelector('input[name="smart-tier"]:checked');
          if (!selected) return alert("Select an option");

          const quantity = Number(selected.value);

          btn.disabled = true;
          btn.textContent = "Adding...";

          try {
            await fetch("/cart/add.js", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
              },
              body: JSON.stringify({
                items: [
                  {
                    id: Number(variantId),
                    quantity: quantity
                  }
                ]
              })
            });

            window.location.href = "/cart";

          } catch (err) {
            alert("Failed to add to cart");
            btn.disabled = false;
            btn.textContent = "Add bundle to cart";
          }
        });

      // Fetch offer
      fetch(`/apps/promotions/storefront/offers?productId=${encodeURIComponent(productGid)}&shop=${encodeURIComponent(shop)}`, {
        headers: { "Accept": "application/json" }
      })
        .then(res => res.json())
        .then(data => {
          const offer = data && data.offers && data.offers[0];
          if (!offer) {
            root.innerHTML = ""; // no offer, show nothing
            return;
          }
          render(offer);
        })
        .catch(err => {
          root.innerHTML = `<div class="smart-offer__error">Offer load failed.</div>`;
          console.error("Offer fetch error:", err);
        });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Offer Widget",
  "target": "section",
  "settings": []
}
{% endschema %}