{% if template.name == 'product' and product %}
  {% assign variant_id = product.selected_or_first_available_variant.id %}
  {% assign variant_price = product.selected_or_first_available_variant.price %}

  <div
    id="smart-offer-root-{{ section.id }}"
    class="smart-offer"
    data-variant-id="{{ variant_id }}"
    data-product-gid="gid://shopify/Product/{{ product.id }}"
    data-price="{{ variant_price }}"
    data-shop="{{ shop.permanent_domain }}">
    <div class="smart-offer__loading">Loading offer…</div>
  </div>

  <style>
  .smart-offer{
    border:1px solid rgba(0,0,0,.12);
    border-radius:14px;
    padding:18px;
    margin-top:14px;
    background:inherit;
    color:inherit;
    font-family:inherit;
  }

  .smart-offer__title{
    display:flex;
    align-items:center;
    gap:10px;
    font-size:1.3em;
    font-weight:700;
    margin:0 0 8px;
  }

  .smart-offer__desc{
    margin:0 0 14px;
    opacity:.8;
  }

  .smart-offer__tiers{
    display:flex;
    flex-direction:column;
    gap:10px;
    margin:0 0 16px;
    padding:0;
    list-style:none;
  }

  .smart-offer__tier{
    border:1px solid rgba(0,0,0,.12);
    border-radius:10px;
    padding:12px;
  }

  .smart-offer__tier label{
    display:flex;
    align-items:center;
    justify-content:space-between;
    cursor:pointer;
  }

  .smart-offer__btn{
    width:100%;
    border-radius:10px;
    padding:12px;
    font-weight:700;
    border:1px solid rgba(0,0,0,.15);
    cursor:pointer;
    background:inherit;
    color:inherit;
  }

  .smart-offer__btn[disabled]{
    opacity:.5;
  }

  .smart-offer-brand{
    margin-top:8px;
    font-size:12px;
    opacity:.55;
    text-align:right;
  }

  .smart-offer__empty{
    border:1px dashed rgba(0,0,0,.15);
    border-radius:12px;
    padding:16px;
    text-align:center;
    font-size:14px;
    opacity:.65;
    background:rgba(0,0,0,.02);
  }

  .smart-offer__pricing{
    border:1px solid rgba(0,0,0,.08);
    border-radius:10px;
    padding:12px;
    margin:12px 0;
    display:flex;
    flex-direction:column;
    gap:6px;
    background:rgba(0,0,0,.02);
  }

  .smart-offer__row{
    display:flex;
    justify-content:space-between;
    font-size:14px;
  }

  .smart-offer__label{
    opacity:.7;
  }

  .smart-offer__value{
    font-weight:500;
  }

  .smart-offer__retail .smart-offer__value{
    text-decoration:line-through;
    opacity:.6;
  }

  .smart-offer__savings .smart-offer__value{
    color:#0a7f3f;
    font-weight:600;
  }

  .smart-offer__deal{
    border-top:1px dashed rgba(0,0,0,.1);
    margin-top:6px;
    padding-top:6px;
    font-size:15px;
  }

  .smart-offer__deal .smart-offer__value{
    font-size:18px;
    font-weight:700;
  }
  </style>

  <script>
  console.log("VERSION: POST_APPROVAL");
  (function () {

    const root = document.getElementById("smart-offer-root-{{ section.id }}");
    if (!root) return;

    const variantId = root.dataset.variantId;
    const productGid = root.dataset.productGid;
    const shop = root.dataset.shop;

    /* ----------------------------- */
    /* Analytics helper              */
    /* ----------------------------- */

    function trackEvent(eventName, offerId, metadata = {}) {

      fetch("/apps/promotions/api/analytics/event", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          eventName,
          offerId,
          metadata,
          shop
        })
      }).catch(err => console.warn("Analytics error:", err));

    }

    let settings = {
      enableAnimations: true,
      showBranding: true
    }

    fetch(`/apps/promotions/storefront/offers?productId=${encodeURIComponent(productGid)}&shop=${encodeURIComponent(shop)}`)
      .then(res => res.json())
      .then(data => {

        if (!data || !data.offers || !data.offers.length) {
         root.innerHTML = `
           <div class="smart-offer__empty">
             No active offer yet.
           </div>
         `;
          return;
        }

        settings = data?.settings || settings;

        const offer = data.offers[0];

        /* -------- TRACK OFFER VIEW -------- */

        const observer = new IntersectionObserver(entries => {

          if (entries[0].isIntersecting) {

            trackEvent("offer_view", offer.id);

            observer.disconnect();

          }

        });

        observer.observe(root);

        if (settings.enableAnimations) {

          root.style.opacity = "0";
          root.style.transform = "translateY(10px)";

          setTimeout(()=>{
            root.style.transition = "all .35s ease";
            root.style.opacity = "1";
            root.style.transform = "translateY(0)";
          },50);

        }

        if (offer.type === "bundle") {
          renderBundle(offer);
          return;
        }

        if (offer.type === "volume_discount" || offer.type === "quantity_break") {
          renderTierOffer(offer);
          return;
        }

        root.innerHTML = "";

      })
      .catch(err => {
        console.error("Offer fetch error:", err);
        root.innerHTML = "";
      });

    /* ----------------------------- */
    /* Bundle Offer                  */
    /* ----------------------------- */

    function renderBundle(offer){

      const currency = window.Shopify?.currency?.active || "GBP";
      const money = new Intl.NumberFormat(undefined,{
        style:"currency",
        currency
      });

      const price = Number(root.dataset.price) / 100;
      console.log("PRICE:", root.dataset.price);

      const quantity = Number(offer.minQuantity || 2);
      const discount = Number(offer.discountValue || 0) / 100;

      const retail = price * quantity;
      const savings = retail * discount;
      const deal = retail - savings;

      root.innerHTML = `
        <div class="smart-offer__title">${offer.name || "Bundle & Save"}</div>
        <p class="smart-offer__desc">
          Buy ${quantity}+ items and save ${offer.discountValue || 0}%
        </p>

        <div class="smart-offer__pricing">

          <div class="smart-offer__row smart-offer__retail">
            <span class="smart-offer__label">Retail Price:</span>
            <span class="smart-offer__value">${money.format(retail)}</span>
          </div>

          <div class="smart-offer__row smart-offer__savings">
            <span class="smart-offer__label">Savings:</span>
            <span class="smart-offer__value">-${money.format(savings)}</span>
          </div>

          <div class="smart-offer__row smart-offer__deal">
            <span class="smart-offer__label">Deal price:</span>
            <span class="smart-offer__value">${money.format(deal)}</span>
          </div>

        </div>

        ${settings.showBranding ? `<div class="smart-offer-brand">Powered by Oban Offers</div>` : ""}
      `;
    }

    /* ----------------------------- */
    /* Tiered Offer                  */
    /* ----------------------------- */

    function renderTierOffer(offer){

      const tiers = Array.isArray(offer.tiers) ? offer.tiers : [];
      if (!tiers.length){
        root.innerHTML = "";
        return;
      }

      const currency = window.Shopify?.currency?.active || "GBP";
      const money = new Intl.NumberFormat(undefined,{
        style:"currency",
        currency
      });

      const price = Number(root.dataset.price) / 100;

      const tierHTML = tiers.map((tier,index)=>{
        return `
          <li class="smart-offer__tier">
            <label>
              <input type="radio" name="smart-tier" value="${tier.quantity}" data-discount="${tier.discount}" ${index===0?"checked":""}>
              <span>Buy ${tier.quantity}+</span>
              <strong>Save ${tier.discount}%</strong>
            </label>
          </li>
        `;
      }).join("");

      const branding = settings.showBranding
        ? `<div class="smart-offer-brand">Powered by Oban All-in-one Offers</div>`
        : "";

      root.innerHTML = `
        <div class="smart-offer__title">${offer.name || "Special Offer"}</div>

        <ul class="smart-offer__tiers">${tierHTML}</ul>

        <div id="smart-offer-pricing" class="smart-offer__pricing"></div>

        <button id="smart-offer-btn" class="smart-offer__btn">Add to cart</button>

        ${branding}
      `;

      const pricingBox = document.getElementById("smart-offer-pricing");

      function updatePricing(){
        const selected = root.querySelector('input[name="smart-tier"]:checked');
        if (!selected) return;

        const quantity = Number(selected.value);
        const discount = Number(selected.dataset.discount) / 100;

        let retail = price * quantity;
        let savings, deal;

        if (offer.type === "volume_discount") {
          // ✅ CURRENT LOGIC (keep as-is)
          savings = retail * discount;
          deal = retail - savings;

        } else if (offer.type === "quantity_break") {
          // ✅ FIXED LOGIC
          const discountedUnit = price * (1 - discount);
          deal = discountedUnit * quantity;
          savings = retail - deal;
        }

        pricingBox.innerHTML = `
          <div class="smart-offer__row smart-offer__retail">
            <span class="smart-offer__label">Retail price:</span>
            <span class="smart-offer__value">${money.format(retail)} (For ${quantity} packs)</span>
          </div>

          <div class="smart-offer__row smart-offer__savings">
            <span class="smart-offer__label">Savings:</span>
            <span class="smart-offer__value">-${money.format(savings)}</span>
          </div>

          <div class="smart-offer__row smart-offer__deal">
            <span class="smart-offer__label">Deal price:</span>
            <span class="smart-offer__value">${money.format(deal)}</span>
          </div>
        `;
      }

      root.querySelectorAll('input[name="smart-tier"]').forEach(input=>{
        input.addEventListener("change", updatePricing);
      });

      updatePricing();

      const btn = document.getElementById("smart-offer-btn");

      btn.addEventListener("click", async () => {

        const selected = root.querySelector('input[name="smart-tier"]:checked');
        if (!selected) return;

        const quantity = Number(selected.value);

        trackEvent("offer_click", offer.id, { quantity });

        btn.disabled = true;
        btn.textContent = "Adding...";

        try{
          await fetch("/cart/add.js",{
            method:"POST",
            headers:{
              "Content-Type":"application/json",
              "Accept":"application/json"
            },
            body:JSON.stringify({
              items:[{ id:Number(variantId), quantity }]
            })
          });

          trackEvent("offer_applied", offer.id, { quantity });
          window.location.href="/cart";

        }catch(err){
          btn.disabled=false;
          btn.textContent="Add to cart";
        }

      });
    }

  })();
  </script>

{% endif %}

{% schema %}
{
  "name": "Offer Widget",
  "target": "section",
  "settings": []
}
{% endschema %}